# Docker Compose gateway. The published address is intentionally fixed to
# 127.0.0.1 in docker-compose.yml; only the local port is configurable.
WEB_PORT=8080

# Optional backend extras declared by backend/pyproject.toml. Supported values:
# analysis-asr, analysis-ocr, or analysis (both). Leave empty when the host
# should expose media/subtitle/summary analysis but not install large ML runtimes.
BACKEND_EXTRAS=

# Application and upstream behavior.
APP_DATABASE_URL=sqlite+aiosqlite:////app/runtime/data/bili_insight.db
APP_LOG_LEVEL=INFO
APP_LOG_JSON=true
APP_METADATA_CACHE_TTL_SECONDS=1200
APP_STREAM_CACHE_TTL_SECONDS=300
APP_UPSTREAM_TIMEOUT_SECONDS=20
APP_UPSTREAM_CONNECT_TIMEOUT_SECONDS=5
APP_UPSTREAM_RETRIES=2
APP_UPSTREAM_MAX_RESPONSE_BYTES=8388608
APP_COOKIE_UPLOAD_MAX_BYTES=1048576
APP_COOKIE_MAX_ITEMS=300

# Cookie encryption is intentionally absent from this file. Docker creates a
# Fernet key in the dedicated bili-insight-secrets volume on first startup.
